# ==============================================================================
# LumiLearn API Configuration Template
# ==============================================================================
# Add your API keys below to enable Live Mode. If these are left blank, the app
# will run in Mock Mode (offline-capable, using free Google Translate TTS and local SVG art).

# ------------------------------------------------------------------------------
# LLM Providers (for Simplification, Storyboarding, and Quiz generation)
# ------------------------------------------------------------------------------
# Gemini API Key (Recommended, cost-effective)
GEMINI_API_KEY=

# OpenAI API Key (Alternative for GPT-4o-mini and DALL-E 3)
OPENAI_API_KEY=

# ------------------------------------------------------------------------------
# Image Generation Providers
# ------------------------------------------------------------------------------
# Replicate API Key (for SDXL/Flux-schnell models)
REPLICATE_API_KEY=

# GMI Cloud API Key (OpenAI-compatible endpoint for Flux inference)
GMI_API_KEY=

# ------------------------------------------------------------------------------
# Text-to-Speech (TTS) Providers
# ------------------------------------------------------------------------------
# ElevenLabs API Key
ELEVENLABS_API_KEY=

# LMNT API Key
LMNT_API_KEY=

# Hume AI API Key
HUME_API_KEY=

# ------------------------------------------------------------------------------
# Backblaze B2 Storage (S3-Compatible API)
# ------------------------------------------------------------------------------
# B2 Application Key ID (corresponds to AWS Access Key ID)
B2_APPLICATION_KEY_ID=

# B2 Application Key (corresponds to AWS Secret Access Key)
B2_APPLICATION_KEY=

# B2 Bucket Name
B2_BUCKET_NAME=

# B2 Endpoint URL (e.g., https://s3.us-east-005.backblazeb2.com)
B2_ENDPOINT_URL=

# B2 Region (e.g., us-east-005)
B2_REGION=
